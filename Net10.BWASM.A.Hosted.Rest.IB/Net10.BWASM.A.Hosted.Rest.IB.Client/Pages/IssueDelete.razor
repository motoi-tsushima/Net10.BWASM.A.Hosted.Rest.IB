@page "/issues/{Id:int}/delete"
@inject IssueApiService IssueApi
@inject NavigationManager Nav

<h3>課題削除</h3>

@if (isLoading)
{
    <p>読み込み中...</p>
}
else if (loadError is not null)
{
    <div class="alert alert-danger">@loadError</div>
}
else if (issue is not null)
{
    <div class="alert alert-warning">この課題を削除しますか？この操作は取り消せません。</div>

    <table class="table mb-3">
        <tbody>
            <tr><th>ID</th><td>@issue.Id</td></tr>
            <tr><th>記入者氏名</th><td>@issue.AuthorName</td></tr>
            <tr><th>記入日時</th><td>@issue.CreatedAt.ToString("yyyy/MM/dd HH:mm:ss")</td></tr>
            <tr><th>カテゴリ</th><td>@issue.Category</td></tr>
            <tr><th>課題タイトル</th><td>@issue.Title</td></tr>
            <tr><th>課題の文面</th><td style="white-space:pre-wrap">@issue.Description</td></tr>
            <tr><th>ステータス</th><td>@issue.Status.ToDisplayName()</td></tr>
            <tr><th>解決の文面</th><td style="white-space:pre-wrap">@issue.Resolution</td></tr>
            <tr><th>解決担当者名</th><td>@issue.ResolverName</td></tr>
            <tr><th>解決日時</th><td>@issue.ResolvedAt?.ToString("yyyy/MM/dd HH:mm:ss")</td></tr>
        </tbody>
    </table>

    @if (errorMessage is not null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <div class="d-flex gap-2">
        <button class="btn btn-danger" @onclick="HandleDelete" disabled="@isDeleting">削除</button>
        <button class="btn btn-secondary" @onclick='() => Nav.NavigateTo($"/issues/{Id}")'>戻る</button>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private IssueDto? issue;
    private bool isLoading = true;
    private string? loadError;
    private string? errorMessage;
    private bool isDeleting;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            issue = await IssueApi.GetByIdAsync(Id);
            if (issue is null) loadError = "課題が見つかりません。";
        }
        catch (Exception ex)
        {
            loadError = $"課題の読み込みに失敗しました: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleDelete()
    {
        isDeleting = true;
        errorMessage = null;
        try
        {
            await IssueApi.DeleteAsync(Id);
            Nav.NavigateTo("/issues");
        }
        catch (Exception ex)
        {
            errorMessage = $"削除に失敗しました: {ex.Message}";
            isDeleting = false;
        }
    }
}
